<Window x:Class="RVStock.BeheerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RVStock - Beheer"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Topbalk -->
        <Border Grid.Row="0" Background="#1565C0">
            <Grid Margin="20 0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙" FontSize="22" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBlock Text="RVStock" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Beheer" FontSize="13" Foreground="#90CAF9" VerticalAlignment="Center" Margin="10 2 0 0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TabControl -->
        <TabControl Grid.Row="1" Margin="20" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="18 8"/>
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#546E7A"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#1565C0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ===== LEVERANCIERS ===== -->
            <TabItem Header="🏭  Leveranciers">
                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="8" Margin="0 0 14 0">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="#E3F2FD" CornerRadius="8 8 0 0" Padding="16 10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Leveranciers" FontSize="14" FontWeight="SemiBold" Foreground="#1565C0"/>
                                    <Button Content="Vernieuwen" Height="26" Padding="10 0" Margin="12 0 0 0"
                                            Background="#1976D2" Foreground="White" BorderThickness="0"
                                            FontSize="11" Cursor="Hand" Click="RefreshLeveranciers_Click"/>
                                </StackPanel>
                            </Border>
                            <DataGrid x:Name="LeveranciersGrid" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F0F0F0" RowHeight="40" FontSize="13"
                                      AlternatingRowBackground="#FAFAFA"
                                      SelectionChanged="LeveranciersGrid_SelectionChanged">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#546E7A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12 10"/>
                                        <Setter Property="BorderThickness" Value="0 0 0 2"/>
                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Naam" Binding="{Binding Naam}" Width="*"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                                    <DataGridTextColumn Header="Besteldag" Binding="{Binding BestelDag}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Formulier -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Leverancier" FontSize="15" FontWeight="Bold"
                                       Foreground="#1565C0" Margin="0 0 0 16"/>

                            <TextBlock Text="Naam" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <TextBox x:Name="LevNaamBox" Height="34" Padding="10 6" FontSize="13"
                                     BorderBrush="#BBDEFB" BorderThickness="2" Margin="0 0 0 12"/>

                            <TextBlock Text="Email" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <TextBox x:Name="LevEmailBox" Height="34" Padding="10 6" FontSize="13"
                                     BorderBrush="#BBDEFB" BorderThickness="2" Margin="0 0 0 12"/>

                            <TextBlock Text="Besteldag" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <ComboBox x:Name="LevBesteldagBox" Height="34" FontSize="13" Margin="0 0 0 20">
                                <ComboBoxItem Content="Maandag" Tag="1"/>
                                <ComboBoxItem Content="Dinsdag" Tag="2"/>
                                <ComboBoxItem Content="Woensdag" Tag="3"/>
                                <ComboBoxItem Content="Donderdag" Tag="4"/>
                                <ComboBoxItem Content="Vrijdag" Tag="5"/>
                                <ComboBoxItem Content="Zaterdag" Tag="6"/>
                                <ComboBoxItem Content="Zondag" Tag="0"/>
                            </ComboBox>

                            <Button Content="💾  Opslaan" Height="36" Background="#1976D2" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="SaveLeverancier_Click" Margin="0 0 0 8"/>
                            <Button Content="➕  Nieuw" Height="36" Background="#43A047" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="NieuweLeverancier_Click" Margin="0 0 0 8"/>
                            <Button Content="🗑  Verwijderen" Height="36" Background="#E53935" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="DeleteLeverancier_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== ONDERDELEN ===== -->
            <TabItem Header="🔧  Onderdelen">
                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="8" Margin="0 0 14 0">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="#E3F2FD" CornerRadius="8 8 0 0" Padding="16 10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Onderdelen" FontSize="14" FontWeight="SemiBold" Foreground="#1565C0"/>
                                    <Button Content="Vernieuwen" Height="26" Padding="10 0" Margin="12 0 0 0"
                                            Background="#1976D2" Foreground="White" BorderThickness="0"
                                            FontSize="11" Cursor="Hand" Click="RefreshOnderdelen_Click"/>
                                </StackPanel>
                            </Border>
                            <DataGrid x:Name="OnderdelenGrid" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F0F0F0" RowHeight="40" FontSize="13"
                                      AlternatingRowBackground="#FAFAFA"
                                      SelectionChanged="OnderdelenGrid_SelectionChanged">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#546E7A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12 10"/>
                                        <Setter Property="BorderThickness" Value="0 0 0 2"/>
                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bestelnummer" Binding="{Binding Bestelnummer}" Width="130"/>
                                    <DataGridTextColumn Header="Benaming" Binding="{Binding Naam}" Width="*"/>
                                    <DataGridTextColumn Header="Categorie" Binding="{Binding Categorie.Naam}" Width="110"/>
                                    <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="140"/>
                                    <DataGridTextColumn Header="Voorraad" Binding="{Binding Voorraad}" Width="80"/>
                                    <DataGridTextColumn Header="Leverancier" Binding="{Binding Leverancier.Naam}" Width="130"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Formulier -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Onderdeel" FontSize="15" FontWeight="Bold"
                                       Foreground="#1565C0" Margin="0 0 0 16"/>

                            <TextBlock Text="Bestelnummer" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <TextBox x:Name="OndBestelnummerBox" Height="34" Padding="10 6" FontSize="13"
                                     BorderBrush="#BBDEFB" BorderThickness="2" Margin="0 0 0 12"/>

                            <TextBlock Text="Benaming" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <TextBox x:Name="OndNaamBox" Height="34" Padding="10 6" FontSize="13"
                                     BorderBrush="#BBDEFB" BorderThickness="2" Margin="0 0 0 12"/>

                            <TextBlock Text="Barcode" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <TextBox x:Name="OndBarcodeBox" Height="34" Padding="10 6" FontSize="13"
                                     BorderBrush="#BBDEFB" BorderThickness="2" Margin="0 0 0 12"/>

                            <TextBlock Text="Aantal in stock" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <TextBox x:Name="OndVoorraadBox" Height="34" Padding="10 6" FontSize="13"
                                     BorderBrush="#BBDEFB" BorderThickness="2" Margin="0 0 0 12"/>

                            <TextBlock Text="Leverancier" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <ComboBox x:Name="OndLeverancierBox" Height="34" FontSize="13"
                                      DisplayMemberPath="Naam" SelectedValuePath="Id" Margin="0 0 0 12"/>

                            <TextBlock Text="Categorie" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <ComboBox x:Name="OndCategorieBox" Height="34" FontSize="13"
                                      DisplayMemberPath="Naam" SelectedValuePath="Id" Margin="0 0 0 20"/>

                            <Button Content="💾  Opslaan" Height="36" Background="#1976D2" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="SaveOnderdeel_Click" Margin="0 0 0 8"/>
                            <Button Content="➕  Nieuw" Height="36" Background="#43A047" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="NieuwOnderdeel_Click" Margin="0 0 0 8"/>
                            <Button Content="🗑  Verwijderen" Height="36" Background="#E53935" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="DeleteOnderdeel_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== CATEGORIEËN ===== -->
            <TabItem Header="📁  Categorieën">
                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="8" Margin="0 0 14 0">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="#E3F2FD" CornerRadius="8 8 0 0" Padding="16 10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Categorieën" FontSize="14" FontWeight="SemiBold" Foreground="#1565C0"/>
                                    <Button Content="Vernieuwen" Height="26" Padding="10 0" Margin="12 0 0 0"
                                            Background="#1976D2" Foreground="White" BorderThickness="0"
                                            FontSize="11" Cursor="Hand" Click="RefreshCategorieën_Click"/>
                                </StackPanel>
                            </Border>
                            <DataGrid x:Name="CategorieënGrid" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F0F0F0" RowHeight="40" FontSize="13"
                                      AlternatingRowBackground="#FAFAFA"
                                      SelectionChanged="CategorieënGrid_SelectionChanged">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#546E7A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12 10"/>
                                        <Setter Property="BorderThickness" Value="0 0 0 2"/>
                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Naam" Binding="{Binding Naam}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Formulier -->
                    <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Categorie" FontSize="15" FontWeight="Bold"
                                       Foreground="#1565C0" Margin="0 0 0 16"/>

                            <TextBlock Text="Naam" FontSize="12" Foreground="#546E7A" Margin="0 0 0 4"/>
                            <TextBox x:Name="CatNaamBox" Height="34" Padding="10 6" FontSize="13"
                                     BorderBrush="#BBDEFB" BorderThickness="2" Margin="0 0 0 20"/>

                            <Button Content="💾  Opslaan" Height="36" Background="#1976D2" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="SaveCategorie_Click" Margin="0 0 0 8"/>
                            <Button Content="➕  Nieuw" Height="36" Background="#43A047" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="NieuweCategorie_Click" Margin="0 0 0 8"/>
                            <Button Content="🗑  Verwijderen" Height="36" Background="#E53935" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="DeleteCategorie_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== BESTELLIJST ===== -->
            <TabItem Header="📋  Open Bestellijst">
                <Grid Margin="0 10 0 0">
                    <Border Background="White" CornerRadius="8">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="#E3F2FD" CornerRadius="8 8 0 0" Padding="16 10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Open bestellijnen" FontSize="14" FontWeight="SemiBold" Foreground="#1565C0"/>
                                    <Button Content="Vernieuwen" Height="26" Padding="10 0" Margin="12 0 0 0"
                                            Background="#1976D2" Foreground="White" BorderThickness="0"
                                            FontSize="11" Cursor="Hand" Click="RefreshBestelijnen_Click"/>
                                </StackPanel>
                            </Border>
                            <DataGrid x:Name="BestelijnenGrid" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F0F0F0" RowHeight="40" FontSize="13"
                                      AlternatingRowBackground="#FAFAFA">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#546E7A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12 10"/>
                                        <Setter Property="BorderThickness" Value="0 0 0 2"/>
                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bestelnummer" Binding="{Binding Onderdeel.Bestelnummer}" Width="140"/>
                                    <DataGridTextColumn Header="Benaming" Binding="{Binding Onderdeel.Naam}" Width="*"/>
                                    <DataGridTextColumn Header="Barcode" Binding="{Binding Onderdeel.Barcode}" Width="150"/>
                                    <DataGridTextColumn Header="Leverancier" Binding="{Binding Onderdeel.Leverancier.Naam}" Width="180"/>
                                    <DataGridTextColumn Header="Aantal" Binding="{Binding Aantal}" Width="80"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
