<Window x:Class="RVStock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RVStock - Stockbeheer"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Topbalk -->
        <Border Grid.Row="0" Background="#1565C0">
            <Grid Margin="20 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📦" FontSize="22" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBlock Text="RVStock" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Stockbeheer" FontSize="13" Foreground="#90CAF9" VerticalAlignment="Center" Margin="10 2 0 0"/>
                    <TextBlock x:Name="VersieText" FontSize="11" Foreground="#64B5F6" VerticalAlignment="Center" Margin="12 3 0 0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚙  Beheer" Height="32" Padding="14 0"
                            Background="#546E7A" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Margin="0 0 10 0" Cursor="Hand"
                            Click="BeheerButton_Click"/>
                    <Button Content="🔄  Vernieuwen" Height="32" Padding="14 0"
                            Background="#1976D2" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Inhoud -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Scanner balk -->
            <Border Background="White" CornerRadius="8" Padding="20 14" Margin="0 0 0 16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Rij 1: categorie filter -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                        <TextBlock Text="📁  Categorie:" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0 0 10 0" Foreground="#546E7A"/>
                        <ComboBox x:Name="CategorieFilterBox" Width="200" Height="32" FontSize="13"
                                  DisplayMemberPath="Naam" SelectedValuePath="Id"
                                  SelectionChanged="CategorieFilterBox_SelectionChanged"/>
                    </StackPanel>
                    <!-- Rij 2: scan -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBlock Text="🔍  Scan barcode:" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0 0 12 0"/>
                        <TextBox x:Name="BarcodeTextBox" Width="280" Height="36" FontSize="14"
                                 Padding="10 6" VerticalContentAlignment="Center"
                                 BorderBrush="#BBDEFB" BorderThickness="2"
                                 KeyDown="BarcodeTextBox_KeyDown"/>
                        <TextBlock Text="Aantal:" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="16 0 8 0" Foreground="#546E7A"/>
                        <TextBox x:Name="AantalScanBox" Width="60" Height="36" FontSize="14"
                                 Padding="10 6" VerticalContentAlignment="Center"
                                 BorderBrush="#BBDEFB" BorderThickness="2" Text="1"/>
                        <Button Content="➖  Uitscannen" Height="36" Padding="14 0" Margin="10 0 0 0"
                                Background="#E53935" Foreground="White" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                Click="UitscanButton_Click"/>
                        <TextBlock x:Name="ScanStatusText" FontSize="13" VerticalAlignment="Center"
                                   Margin="14 0 0 0" Foreground="#4CAF50"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tabel -->
            <Border Grid.Row="1" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#E3F2FD" CornerRadius="8 8 0 0" Padding="16 10">
                        <Grid>
                            <TextBlock Text="Overzicht onderdelen" FontSize="14"
                                       FontWeight="SemiBold" Foreground="#1565C0"/>
                            <TextBlock x:Name="AantalItemsText" HorizontalAlignment="Right"
                                       FontSize="12" Foreground="#78909C" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="ProductsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0"
                              RowHeight="42"
                              FontSize="13"
                              AlternatingRowBackground="#FAFAFA"
                              SelectionMode="Single">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#546E7A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="12 10"/>
                                <Setter Property="BorderThickness" Value="0 0 0 2"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12 0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Bestelnummer" Binding="{Binding Bestelnummer}" Width="140"/>
                            <DataGridTextColumn Header="Benaming" Binding="{Binding Naam}" Width="*"/>
                            <DataGridTextColumn Header="Categorie" Binding="{Binding Categorie.Naam}" Width="120"/>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="160"/>
                            <DataGridTextColumn Header="Leverancier" Binding="{Binding Leverancier.Naam}" Width="160"/>
                            <DataGridTemplateColumn Header="Voorraad" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="12 3" HorizontalAlignment="Left" Margin="8 0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Voorraad}" Value="0">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Voorraad}" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Voorraad}" Value="0">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
